<!DOCTYPE html>
<html lang="en">

<head>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Verification | HyperBoard</title>
    <link href="/style.css?v=<%= new Date().getTime() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <style>
        .invite-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .invite-card {
            max-width: 400px;
            width: 100%;
            animation: fadeInUp 0.6s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .shake {
            animation: shake 0.5s ease-in-out;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    </style>
</head>

<body
    class="bg-bp-black text-bp-text min-h-screen flex flex-col font-sans">

    <div class="retro-stripe"></div>

    <div class="invite-container">
        <div class="invite-card card-bp">
            <!-- Lock Icon -->
            <div class="flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-700" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>

            <!-- Header -->
            <div class="text-center mb-4">
                <h1 class="retro-title text-xl mb-1">
                    <span class="text-bp-blue">Hyper</span><span class="text-black">Board</span>
                </h1>
                <p class="text-gray-600 text-xs">--- Private Access Required ---</p>
            </div>

            <hr class="retro-hr mb-4">

            <!-- Description -->
            <p class="text-center text-gray-700 text-xs mb-4">
                This is a private community. Please enter your invitation code to continue.
            </p>

            <!-- Form -->
            <form id="invite-form" class="space-y-3">
                <div>
                    <label for="invite-code" class="block mb-1 text-xs font-bold text-gray-700">
                        Invitation Code:
                    </label>
                    <input type="text" id="invite-code" name="code"
                        class="input-bp text-center text-base tracking-wider font-mono"
                        placeholder="Enter code..." autocomplete="off" required>
                </div>

                <!-- Error Message -->
                <div id="error-message"
                    class="hidden text-red-800 text-xs font-bold p-2 bg-[#FFC0C0] border-2 text-center"
                    style="border-style: inset; border-color: #808080;">
                </div>

                <!-- Submit Button -->
                <button type="submit" id="submit-btn"
                    class="btn-bp-primary w-full justify-center py-2 text-sm font-bold">
                    <span>>> Verify Access &lt;&lt;</span>
                </button>
            </form>

            <!-- Footer -->
            <hr class="retro-hr mt-4 mb-3">
            <div class="text-center">
                <p class="text-[10px] text-gray-500 mb-2">
                    Protected by invitation access control
                </p>
                <a href="https://github.com/carterwayneskhizeine/HyperBoard" target="_blank" rel="noopener noreferrer"
                    class="text-bp-blue underline text-[10px] hover:text-bp-blue-dim">
                    [GitHub Repository]
                </a>
            </div>
        </div>
    </div>

    <div class="retro-stripe" style="position: fixed; bottom: 0; width: 100%;"></div>

    <script>
        const form = document.getElementById('invite-form');
        const codeInput = document.getElementById('invite-code');
        const errorDiv = document.getElementById('error-message');
        const submitBtn = document.getElementById('submit-btn');

        // Get redirect URL from query parameter or default to root
        const urlParams = new URLSearchParams(window.location.search);
        const redirectTo = urlParams.get('redirect') || '/';

        function showError(message) {
            errorDiv.textContent = message;
            errorDiv.classList.remove('hidden');
            form.classList.add('shake');
            setTimeout(() => form.classList.remove('shake'), 500);
        }

        function clearError() {
            errorDiv.classList.add('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            clearError();

            const code = codeInput.value.trim();

            if (!code) {
                showError('Please enter an invitation code');
                return;
            }

            // Disable button and show loading state
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span>Verifying...</span>';

            try {
                const response = await fetch('/api/invite/verify', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ code })
                });

                const data = await response.json();

                if (response.ok) {
                    // Success - redirect to intended destination
                    window.location.href = data.redirectTo || redirectTo;
                } else {
                    showError(data.error || 'Invalid invitation code');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<span>>> Verify Access &lt;&lt;</span>';
                }
            } catch (error) {
                console.error('Verification error:', error);
                showError('Network error. Please try again.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>>> Verify Access &lt;&lt;</span>';
            }
        });

        // Auto-focus input on page load
        codeInput.focus();

        // Allow Enter key to submit
        codeInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                form.dispatchEvent(new Event('submit'));
            }
        });
    </script>
</body>

</html>
