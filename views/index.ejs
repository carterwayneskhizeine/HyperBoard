<!DOCTYPE html>
<html lang="en">

<head>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HyperBoard | Anonymous Board</title>
    <link href="/style.css?v=<%= new Date().getTime() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>

<body
    class="bg-bp-black text-bp-text min-h-screen flex flex-col font-sans">

    <!-- Retro Top Stripe -->
    <div class="retro-stripe"></div>

    <!-- Sticky Header -->
    <header
        class="sticky top-0 z-50 bg-[#C0C0C0] border-b-2 border-[#808080] h-12">
        <div class="max-w-7xl mx-auto px-2 h-full flex items-center justify-between">
            <!-- Brand -->
            <div class="flex items-center gap-3">
                <button id="sidebar-toggle-btn"
                    class="hidden lg:block text-black hover:bg-[#D4D0C8] p-1 border border-transparent hover:border-[#808080]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <h1 class="retro-title text-lg select-none cursor-pointer"
                    onclick="window.location.reload()">
                    <span class="text-bp-blue">Hyper</span><span class="text-black">Board</span>
                </h1>
                <!-- "NEW!" blink -->
                <span class="text-red-600 text-xs font-bold animate-blink hidden md:inline">NEW!</span>

                <!-- Desktop Search Container -->
                <div id="desktop-search-container"
                    class="hidden md:block relative ml-2">
                    <input id="desktop-search-input" type="text" placeholder="Search..."
                        class="input-bp py-1 pl-2 pr-3 text-xs w-48 focus:w-64 transition-all">
                </div>

                <!-- Mobile Search Toggle -->
                <button id="mobile-search-toggle"
                    class="md:hidden text-black hover:bg-[#D4D0C8] p-1 border border-transparent hover:border-[#808080]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>
            </div>

            <!-- User Area -->
            <div id="user-area" class="flex items-center gap-2">
                <!-- Guest view -->
                <div id="guest-view" class="<%= user ? 'hidden' : '' %>">
                    <button id="login-btn" class="btn-bp-primary text-xs py-1 px-3">
                        Login
                    </button>
                </div>

                <!-- User view -->
                <div id="user-view" class="<%= user ? '' : 'hidden' %> relative">
                    <!-- User menu trigger -->
                    <button id="user-menu-trigger"
                        class="flex items-center gap-2 text-xs text-black hover:bg-[#D4D0C8] py-1 px-2 border border-transparent hover:border-[#808080]">
                        <span id="username-display" class="hidden sm:inline-block text-bp-blue font-bold">
                            <%= user ? user.username : '' %>
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- User dropdown menu -->
                    <div id="user-dropdown-menu"
                        class="hidden absolute right-0 mt-1 w-52 bg-[#C0C0C0] border-2 border-outset z-50"
                        style="border-style: outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
                        <!-- User info header -->
                        <div class="px-3 py-2 border-b border-[#808080]">
                            <p class="text-xs text-gray-600">Signed in as</p>
                            <p id="dropdown-username" class="text-xs font-bold text-bp-blue">
                                <%= user ? user.username : '' %>
                            </p>
                        </div>

                        <!-- Menu items -->
                        <div class="py-1">
                            <button id="change-password-btn"
                                class="w-full flex items-center gap-2 px-3 py-1.5 text-xs text-black hover:bg-[#0000FF] hover:text-white text-left">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                                </svg>
                                Change Password
                            </button>
                        </div>

                        <div class="border-t border-[#808080]"></div>

                        <div class="py-1">
                            <button id="logout-btn"
                                class="w-full flex items-center gap-2 px-3 py-1.5 text-xs text-red-800 hover:bg-[#FF0000] hover:text-white text-left">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                Logout
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Mobile Search Container -->
    <div id="mobile-search-container" class="hidden md:hidden bg-[#C0C0C0] p-2 border-b-2 border-[#808080]">
        <div class="relative">
            <input id="mobile-search-input" type="text" placeholder="Search..."
                class="input-bp py-1 pl-2 pr-3 text-xs w-full">
        </div>
    </div>

    <!-- Main Grid -->
    <div class="flex-1 max-w-7xl w-full mx-auto p-2 lg:p-3 grid grid-cols-1 lg:grid-cols-12 gap-3">

        <!-- Sidebar (Desktop) -->
        <aside id="desktop-sidebar" class="hidden lg:hidden lg:col-span-3 space-y-3">
            <!-- Filter Widget -->
            <div class="retro-groupbox sticky top-14">
                <fieldset>
                    <legend class="retro-groupbox-title text-xs">Feeds</legend>
                    <nav class="flex flex-col space-y-0.5 mt-1">
                        <button id="feed-latest-btn"
                            class="flex items-center gap-2 px-2 py-1 text-xs text-black bg-[#D4D0C8] border border-[#808080] font-bold text-left w-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Latest
                        </button>
                        <button id="feed-trending-btn"
                            class="flex items-center gap-2 px-2 py-1 text-xs text-black hover:bg-[#D4D0C8] text-left w-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                            Trending
                        </button>
                        <button id="feed-liked-btn"
                            class="<%= user ? '' : 'hidden' %> flex items-center gap-2 px-2 py-1 text-xs text-black hover:bg-[#D4D0C8] text-left w-full">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="h-3 w-3" viewBox="0 0 20 20"
                                fill="currentColor">
                                <path fill-rule="evenodd"
                                    d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
                                    clip-rule="evenodd" />
                            </svg>
                            Liked
                        </button>
                        <button id="feed-posts-btn"
                            class="<%= user ? '' : 'hidden' %> flex items-center gap-2 px-2 py-1 text-xs text-black hover:bg-[#D4D0C8] text-left w-full">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="h-3 w-3" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            Posts
                        </button>
                        <button id="feed-private-btn"
                            class="<%= user ? '' : 'hidden' %> flex items-center gap-2 px-2 py-1 text-xs text-black hover:bg-[#D4D0C8] text-left w-full">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="h-3 w-3" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Private
                        </button>
                    </nav>

                    <hr class="retro-hr my-2">

                    <div class="text-xs text-gray-600 bg-white p-2 mt-1" style="border: 2px inset #808080;">
                        <p class="mb-1">Welcome to <a href="#" class="text-bp-blue underline">HyperBoard</a>.</p>
                        <p class="text-[10px] text-gray-500">v2.0</p>
                    </div>
                </fieldset>
            </div>
        </aside>

        <!-- Main Content -->
        <main id="main-content" class="lg:col-span-12 lg:flex lg:justify-center">
            <div id="main-content-wrapper" class="space-y-3 lg:w-3/4">

                <!-- Message Composer -->
                <div class="card-bp">
                    <div class="text-xs font-bold text-black mb-2">-- Post a Message --</div>
                    <form id="message-form" class="flex flex-col gap-3">
                        <!-- Text Area -->
                        <textarea id="message-input" name="content" class="input-bp min-h-[100px] resize-y" rows="3"
                            placeholder="What's on your mind?"></textarea>

                        <!-- File Preview (Hidden by default) -->
                        <div class="flex flex-col gap-2">
                            <div class="flex items-center gap-2">
                                <input type="file" id="file-upload" accept="*" class="hidden">
                                <span id="file-status" class="text-xs text-gray-600 hidden">No file selected</span>
                            </div>
                            <div id="file-preview-container" class="hidden">
                                <div class="relative inline-block mt-1">
                                    <div id="file-preview-content"
                                        class="max-h-56 bg-white p-2"
                                        style="border: 2px inset #808080;">
                                        <div id="file-preview-icon" class="text-center mb-1"></div>
                                        <div id="file-preview-name"
                                            class="text-center text-xs text-black break-all font-mono"></div>
                                        <div id="file-preview-type" class="text-center text-[10px] text-gray-500 mt-1">
                                        </div>
                                        <div id="file-preview-size" class="text-center text-[10px] text-gray-500 mt-1">
                                        </div>
                                    </div>
                                    <button type="button" id="remove-file-button"
                                        class="absolute -top-1 -right-1 bg-[#C0C0C0] text-red-600 border border-[#808080] p-0.5 hover:bg-[#FFC0C0] text-xs font-bold"
                                        style="border-style: outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
                                        X
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Actions Bar -->
                        <div class="retro-hr"></div>

                        <div
                            class="flex flex-row flex-wrap gap-2 items-center justify-between">

                            <!-- Left: KEY Controls -->
                            <div class="flex items-center gap-2">
                                <button type="button" id="key-button"
                                    class="btn-bp-outline text-[10px] h-7 px-2 flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                        class="h-3 w-3 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                                    </svg>
                                    KEY
                                </button>

                                <input type="text" id="private-key-input" placeholder="Private key..."
                                    class="hidden input-bp h-7 py-0 text-xs w-full sm:w-40 font-mono">

                                <button type="button" id="send-key-button"
                                    class="hidden btn-bp-primary text-[10px] h-7 px-3">
                                    Send
                                </button>
                            </div>

                            <!-- Right: Upload & Post -->
                            <div class="flex items-center gap-2 ml-auto">
                                <!-- File Upload Trigger -->
                                <button type="button" id="upload-file-button" class="btn-bp-icon" title="Upload File">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none"
                                        viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                                    </svg>
                                </button>

                                <!-- StackEdit Trigger -->
                                <button type="button" id="stackedit-button"
                                    class="btn-bp-outline h-7 flex items-center gap-1 px-2 text-[10px]"
                                    title="Edit with StackEdit">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                        class="h-3 w-3 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    <span>MD</span>
                                </button>

                                <button type="submit" id="post-message-button"
                                    class="btn-bp-primary h-7 flex items-center gap-1 px-4 text-xs">
                                    <span>Post</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none"
                                        viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Error Message -->
                        <div id="error-message"
                            class="hidden text-red-800 text-xs font-bold p-2 bg-[#FFC0C0] border-2 text-center"
                            style="border-style: inset; border-color: #808080;"
                            role="alert"></div>
                    </form>
                </div>

                <!-- Mobile Filters (Horizontal Scroll) -->
                <div class="lg:hidden flex gap-1 overflow-x-auto pb-1 no-scrollbar">
                    <button id="mobile-feed-latest-btn"
                        class="btn-bp-primary text-[10px] whitespace-nowrap px-3 py-1 h-auto">Latest</button>
                    <button id="mobile-feed-trending-btn"
                        class="btn-bp-outline text-[10px] whitespace-nowrap px-3 py-1 h-auto">Trending</button>
                    <button id="mobile-feed-liked-btn"
                        class="<%= user ? '' : 'hidden' %> btn-bp-outline text-[10px] whitespace-nowrap px-3 py-1 h-auto">Liked</button>
                    <button id="mobile-feed-posts-btn"
                        class="<%= user ? '' : 'hidden' %> btn-bp-outline text-[10px] whitespace-nowrap px-3 py-1 h-auto">Posts</button>
                    <button id="mobile-feed-private-btn"
                        class="<%= user ? '' : 'hidden' %> btn-bp-outline text-[10px] whitespace-nowrap px-3 py-1 h-auto">Private</button>
                </div>

                <!-- Message List -->
                <div id="message-list" class="space-y-3">
                    <!-- Content injected via JS -->
                </div>

                <!-- Pagination -->
                <div id="pagination-container" class="py-4 flex justify-center"></div>

            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="mt-auto border-t-2 border-[#808080] py-4 bg-[#C0C0C0]">
        <div class="max-w-7xl mx-auto px-2 text-center">
            <p class="text-gray-600 text-xs">&copy; 2025 Goldie Rill. All rights reserved.</p>
            <p class="text-[10px] text-gray-500 mt-1">Best viewed in Netscape Navigator 4.0+ or Internet Explorer 5.0+</p>
            <div class="flex justify-center mt-2">
                <a href="https://github.com/carterwayneskhizeine/HyperBoard" target="_blank" rel="noopener noreferrer"
                    class="text-bp-blue underline text-xs hover:text-bp-blue-dim">
                    [GitHub]
                </a>
            </div>
        </div>
    </footer>
    <div class="retro-stripe"></div>

    <!-- Modals -->

    <!-- Admin Private Modal -->
    <dialog id="admin-private-modal"
        class="bg-[#C0C0C0] text-black p-4 max-w-sm w-full m-auto"
        style="border: 2px outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
        <h2 class="retro-title text-base mb-3">Make Message Private</h2>
        <p class="text-xs text-gray-700 mb-3">Set a KEY to convert this message to private:</p>
        <div id="admin-private-key-entry">
            <label for="admin-modal-private-key" class="block mb-1 text-xs font-bold text-gray-700">Secret KEY:</label>
            <input type="text" id="admin-modal-private-key" placeholder="Enter custom KEY..." class="input-bp mb-3">
            <div class="flex justify-end gap-2">
                <button id="admin-cancel-private" class="btn-bp-outline text-xs">Cancel</button>
                <button id="admin-confirm-private" class="btn-bp-primary text-xs">Confirm</button>
            </div>
        </div>
    </dialog>

    <!-- Message Type Modal -->
    <dialog id="message-type-modal"
        class="bg-[#C0C0C0] text-black p-4 max-w-sm w-full m-auto"
        style="border: 2px outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
        <h2 class="retro-title text-base mb-4 text-center">Choose Message Type</h2>
        <div id="type-selection" class="flex flex-col gap-2">
            <button id="public-option" class="btn-bp-primary w-full justify-center py-2">Public Message</button>
            <button id="private-option" class="btn-bp-outline w-full justify-center py-2">Private Message</button>
        </div>
        <div id="private-key-entry" class="hidden mt-3">
            <label for="modal-private-key" class="block mb-1 text-xs font-bold text-gray-700">Set a KEY:</label>
            <input type="text" id="modal-private-key" placeholder="Secret Key..." class="input-bp mb-3">
            <div class="flex justify-end gap-2">
                <button id="cancel-private" class="btn-bp-outline text-xs">Cancel</button>
                <button id="confirm-private" class="btn-bp-primary text-xs">Confirm</button>
            </div>
        </div>
    </dialog>

    <!-- Login Modal -->
    <dialog id="login-modal"
        class="bg-[#C0C0C0] text-black p-4 max-w-sm w-full m-auto"
        style="border: 2px outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
        <div class="retro-title text-sm mb-3">Login</div>
        <hr class="retro-hr mb-3">
        <form id="login-form" class="space-y-3">
            <input type="text" id="login-username" placeholder="Username" class="input-bp">
            <input type="password" id="login-password" placeholder="Password" class="input-bp">
            <div id="login-error" class="text-red-800 text-xs hidden"></div>
            <div class="flex justify-between items-center mt-3">
                <button type="button" id="register-from-login"
                    class="text-[10px] text-bp-blue underline hover:text-bp-blue-dim">Create Account</button>
                <div class="flex gap-2">
                    <button type="button" id="cancel-login" class="btn-bp-outline text-xs py-1">Cancel</button>
                    <button type="submit" class="btn-bp-primary text-xs py-1">Login</button>
                </div>
            </div>
        </form>
    </dialog>

    <!-- Register Modal -->
    <dialog id="register-modal"
        class="bg-[#C0C0C0] text-black p-4 max-w-sm w-full m-auto"
        style="border: 2px outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
        <div class="retro-title text-sm mb-3">Register</div>
        <hr class="retro-hr mb-3">
        <form id="register-form" class="space-y-3">
            <input type="text" id="register-username" placeholder="Username (3-20 chars)" class="input-bp">
            <input type="password" id="register-password" placeholder="Password (min 6 chars)" class="input-bp">
            <input type="password" id="register-confirm-password" placeholder="Confirm Password" class="input-bp">
            <div id="register-error" class="text-red-800 text-xs hidden"></div>
            <div class="flex justify-end gap-2 mt-3">
                <button type="button" id="cancel-register" class="btn-bp-outline text-xs py-1">Cancel</button>
                <button type="submit" class="btn-bp-primary text-xs py-1">Register</button>
            </div>
        </form>
    </dialog>

    <!-- Change Password Modal -->
    <dialog id="change-password-modal"
        class="bg-[#C0C0C0] text-black p-4 max-w-sm w-full m-auto"
        style="border: 2px outset; border-color: #DFDFDF #808080 #808080 #DFDFDF;">
        <div class="retro-title text-sm mb-3">Change Password</div>
        <hr class="retro-hr mb-3">
        <form id="change-password-form" class="space-y-3">
            <input type="password" id="current-password" placeholder="Current Password" class="input-bp" required>
            <input type="password" id="new-password" placeholder="New Password (min 6 chars)" class="input-bp" required>
            <input type="password" id="confirm-new-password" placeholder="Confirm New Password" class="input-bp" required>
            <div id="change-password-error" class="text-red-800 text-xs hidden"></div>
            <div class="flex justify-end gap-2 mt-3">
                <button type="button" id="cancel-change-password" class="btn-bp-outline text-xs py-1">Cancel</button>
                <button type="submit" class="btn-bp-primary text-xs py-1">Change</button>
            </div>
        </form>
    </dialog>

    <script src="/js/vendor/showdown.min.js?v=<%= Date.now() %>"></script>
    <script src="/js/vendor/mermaid.min.js?v=<%= Date.now() %>"></script>
    <script>
        mermaid.initialize({
            startOnLoad: false,
            theme: 'default',
            securityLevel: 'loose',
            fontFamily: '"Courier New", Courier, monospace'
        });
    </script>
    <script src="/js/vendor/stackedit.min.js?v=<%= Date.now() %>"></script>
    <script type="module" src="/js/main.js?v=<%= Date.now() %>"></script>
</body>

</html>
